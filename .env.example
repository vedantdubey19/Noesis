POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=noesis
POSTGRES_USER=noesis
POSTGRES_PASSWORD=noesis

REDIS_URL=redis://localhost:6379/0

NOTION_API_KEY=your_notion_api_key
GMAIL_CREDENTIALS_PATH=backend/credentials.json
GMAIL_TOKEN_PATH=backend/token.json

API_AUTH_TOKEN=dev-secret-token

# Week 2 — Chunking
CHUNK_SIZE=400
CHUNK_OVERLAP=50
CHUNK_MIN_CHARS=100

# Week 2 — Embeddings
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100
EMBEDDING_RATE_LIMIT_RPM=500

# Week 2 — Search
VECTOR_SIMILARITY_THRESHOLD=0.75
VECTOR_MAX_RESULTS=10
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7
RRF_K=60

# Week 3 — LLM Pipeline
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1024
PIPELINE_TIMEOUT_SECONDS=8
PIPELINE_MAX_RETRIES=2

# Week 3 — Context Cache
CONTEXT_CACHE_TTL_SECONDS=300
CONTEXT_CACHE_MAX_KEYS=1000

# Week 3 — Stage tuning
STAGE1_MAX_TOKENS=256
STAGE2_MAX_TOKENS=256
STAGE3_MAX_TOKENS=512
STAGE4_MAX_TOKENS=512
